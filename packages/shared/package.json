{
  "name": "@web3nz/shared",
  "version": "0.0.2",
  "description": "Shared types, network constants, EIP-712 helpers and Supabase client factories for the web3nz x402 payment stack",
  "keywords": ["x402", "avalanche", "usdc", "eip-712", "web3", "ai-agents", "supabase"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Igordro1d/web3_hackathon"
  },
  "files": ["dist", "README.md"],
  "publishConfig": { "access": "public" },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "viem": "^2.21.0"
  }
}
